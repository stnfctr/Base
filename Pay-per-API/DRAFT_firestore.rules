rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // APIs: Publicly readable marketplace
    match /apis/{apiId} {
      allow read: if true;
      allow write: if false; // System only
    }

    // Users: Profiles and balances
    match /users/{userId} {
      allow read: if isOwner(userId);
      // In a real app, balance updates are server-side. 
      // For this demo, we'll simulate the "Call" via an Express endpoint.
      allow write: if false; 
    }

    // Transactions: Private logs
    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId);
      allow write: if false; // System only
    }
  }
}
